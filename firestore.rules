rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function operationsUser() {
      return request.auth != null;
    }

    match /menu/{item} {
      allow read: if true;
      allow write: if false;
    }

    match /orders/{order} {
      allow create: if request.resource.data.table is int
                    && request.resource.data.keys().hasOnly([
                      'table',
                      'items',
                      'total',
                      'note',
                      'status',
                      'discount',
                      'paymentMode',
                      'createdAt'
                    ])
                    && request.resource.data.table >= 1
                    && request.resource.data.table <= 10
                    && request.resource.data.status == 'New'
                    && request.resource.data.items is list
                    && request.resource.data.items.size() > 0
                    && request.resource.data.items.size() <= 50
                    && request.resource.data.total is number
                    && request.resource.data.total >= 0
                    && request.resource.data.note is string
                    && request.resource.data.note.size() <= 300
                    && request.resource.data.discount == 0
                    && request.resource.data.paymentMode == null
                    && request.resource.data.createdAt is timestamp;

      allow read: if operationsUser();

      allow update: if operationsUser()
                    && request.resource.data.diff(resource.data)
                         .affectedKeys()
                         .hasOnly([
                           'status',
                           'discount',
                           'paymentMode',
                           'memoNumber',
                           'completedAt'
                         ])
                    && request.resource.data.status in [
                      'New',
                      'Preparing',
                      'Ready',
                      'Completed'
                    ];

      allow delete: if false;
    }
  }
}
